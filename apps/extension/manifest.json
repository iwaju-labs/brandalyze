{
  "manifest_version": 3,
  "name": "Brandalyze - Social Media Brand Analysis",
  "version": "1.0.0",
  "description": "Real-time brand analysis for social media content. Analyse posts and comments for brand alignment while browsing Twitter, LinkedIn, and more.",
  "permissions": ["activeTab", "storage", "identity", "scripting", "tabs"],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://linkedin.com/*",
    "https://www.linkedin.com/*",
    "http://localhost:3000/*",
    "http://localhost:8000/*",
    "https://brandalyze.io/*",
    "https://brandalyze.onrender.com/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content/shared.js", "content/twitter.js"],
      "css": [],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://linkedin.com/*", "https://www.linkedin.com/*"],
      "js": ["content/shared.js", "content/linkedin.js"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Brandalyze Extension"
  },
  "icons": {
    "16": "assets/icon16.svg"
  },

  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
