{
  "manifest_version": 3,
  "name": "Brandalyze - Social Media Brand Analysis",
  "version": "0.3.0",
  "description": "Real-time brand analysis for social media content. Analyse posts/profiles for brand alignment while browsing social media.",
  "permissions": ["activeTab", "storage", "identity", "scripting", "tabs"],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://linkedin.com/*",
    "https://www.linkedin.com/*",
    "http://localhost:3000/*",
    "http://localhost:8000/*",
    "https://brandalyze.io/*",
    "https://www.brandalyze.io/*",
    "https://brandalyze.onrender.com/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content/shared.js", "content/twitter.js"],
      "css": [],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://linkedin.com/*", "https://www.linkedin.com/*"],
      "js": ["content/shared.js", "content/linkedin.js"],
      "css": [],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "https://brandalyze.io/*",
        "https://www.brandalyze.io/*"
      ],
      "js": ["content/brandalyze-sync.js"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Brandalyze Extension"
  },
  "options_ui": {
    "page": "popup/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
